# ─── Stratum Configuration ──────────────────────────────
# Copy this file to .env and fill in your values

# ─── Database ───────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./stratum.db

# ─── Authentication ─────────────────────────────────────
# API key for MVP auth (leave empty for open dev mode)
STRATUM_API_KEY=
# JWT secret for token signing (MUST change in production)
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24

# ─── AI / LLM ──────────────────────────────────────────
# Anthropic API key for Claude-powered executive narratives
ANTHROPIC_API_KEY=

# ─── Vulnerability Database ─────────────────────────────
NVD_API_KEY=

# ─── GitHub Connector ──────────────────────────────────
GITHUB_TOKEN=

# ─── Jira Connector ────────────────────────────────────
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=

# ─── Stripe Billing ────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── SonarQube ──────────────────────────────────────────
SONARQUBE_URL=
SONARQUBE_TOKEN=

# ─── Server ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
LOG_FORMAT=json
RATE_LIMIT_RPM=60
